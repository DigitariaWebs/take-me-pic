{
  "expo": {
    "name": "Take Me Pic",
    "slug": "take-me-pic",
    "scheme": "tmp",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.takemepic.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Take Me Pic uses your location to find photographers nearby and only during an active session.",
        "NSCameraUsageDescription": "Take Me Pic uses the camera to capture photos during a session.",
        "NSPhotoLibraryUsageDescription": "Take Me Pic accesses your photo library to share and save photos from your sessions.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.takemepic.app",
      "adaptiveIcon": {
        "backgroundColor": "#f1e6cf",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "config": {
        "googleMaps": {
          "apiKey": "REPLACE_WITH_ANDROID_GOOGLE_MAPS_API_KEY"
        }
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-image",
      "expo-splash-screen",
      "expo-localization",
      [
        "expo-maps",
        {
          "requestLocationPermission": true,
          "locationPermission": "Take Me Pic utilise ta position pour trouver des photographes à proximité, uniquement pendant une session active."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ac50917d-93e1-41e0-829e-44ca57ba2c3f"
      }
    },
    "owner": "atou4"
  }
}
